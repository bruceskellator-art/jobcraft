<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
@page { size: A4; margin: 1.4cm 1.6cm; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-size: 9.5pt;
  color: #000;
  line-height: 1.35;
}
a { color: inherit; text-decoration: none; }

/* Header */
.header { text-align: center; margin-bottom: 6pt; }
.header h1 {
  font-size: 20pt;
  font-weight: bold;
  letter-spacing: 0.5pt;
  margin-bottom: 4pt;
}
.contact {
  font-size: 8.5pt;
  color: #000;
}
.contact span + span::before { content: " \25A0 "; font-size: 6pt; vertical-align: middle; }
.header hr { border: none; border-top: 1px solid #000; margin-top: 5pt; }

/* Section */
section { margin-top: 8pt; }
.section-title {
  font-size: 8pt;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 0.8pt;
  border-bottom: 1px solid #000;
  padding-bottom: 1pt;
  margin-bottom: 5pt;
}

/* Experience entry */
.entry { margin-bottom: 6pt; }
.entry-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.entry-title { font-weight: bold; font-size: 9.5pt; }
.entry-date { font-size: 8.5pt; white-space: nowrap; }
.entry-sub { font-size: 8.5pt; margin-bottom: 2pt; }
.entry ul { padding-left: 0; list-style: none; }
.entry li { font-size: 9pt; padding-left: 0.8em; text-indent: -0.8em; line-height: 1.3; margin-bottom: 1pt; }
.entry li::before { content: "- "; }

/* Education */
.edu-entry { margin-bottom: 5pt; }
.edu-header { display: flex; justify-content: space-between; }
.edu-degree { font-weight: bold; }
.edu-detail { font-size: 8.5pt; }

/* Skills */
.skill-row { font-size: 9pt; margin-bottom: 2pt; }
.skill-label { font-weight: bold; }
</style>
</head>
<body>

<div class="header">
  <h1>{{ data.name }}</h1>
  <div class="contact">
    {% if data.location %}<span>{{ data.location }}</span>{% endif %}
    {% if data.email %}<span>{{ data.email }}</span>{% endif %}
    {% if data.phone %}<span>{{ data.phone }}</span>{% endif %}
    {% if data.linkedin %}<span>{{ data.linkedin }}</span>{% endif %}
    {% if data.github %}<span>{{ data.github }}</span>{% endif %}
  </div>
  <hr>
</div>

{% if data.summary %}
<section>
  <div class="section-title">Professional Summary</div>
  <p style="font-size:9pt; line-height:1.4;">{{ data.summary }}</p>
</section>
{% endif %}

{% if data.experience %}
<section>
  <div class="section-title">Professional Experience</div>
  {% for exp in data.experience %}
  <div class="entry">
    <div class="entry-header">
      <span class="entry-title">{{ exp.title }}</span>
      <span class="entry-date">{{ exp.start_date }} — {{ exp.end_date }}{% if exp.location %}, {{ exp.location }}{% endif %}</span>
    </div>
    <div class="entry-sub">{{ exp.company }}</div>
    <ul>
      {% for bullet in exp.bullets %}
      <li>{{ bullet }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.projects %}
<section>
  <div class="section-title">Consultancy</div>
  {% for proj in data.projects %}
  <div class="entry">
    <div class="entry-header">
      <span class="entry-title">{{ proj.role or proj.name }}{% if proj.organization %} | {{ proj.organization }}{% endif %}</span>
      {% if proj.start_date %}<span class="entry-date">{{ proj.start_date }}{% if proj.end_date %} — {{ proj.end_date }}{% endif %}</span>{% endif %}
    </div>
    <ul>
      {% for bullet in proj.bullets %}
      <li>{{ bullet }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.education %}
<section>
  <div class="section-title">Education</div>
  {% for edu in data.education %}
  <div class="edu-entry">
    <div class="edu-header">
      <span class="edu-degree">{{ edu.degree }}</span>
      <span class="entry-date">{{ edu.institution }}{% if edu.location %} — {{ edu.location }}{% endif %} | {{ edu.year }}</span>
    </div>
    {% if edu.honors %}<div class="edu-detail">{{ edu.honors }}</div>{% endif %}
    {% if edu.minor %}<div class="edu-detail">Minor in {{ edu.minor }}</div>{% endif %}
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.skills %}
<section>
  <div class="section-title">Expert-Level Skills</div>
  {% for cat in data.skills %}
  <div class="skill-row"><span class="skill-label">{{ cat.category }}:</span> {{ cat.skills | join(', ') }}</div>
  {% endfor %}
</section>
{% endif %}

</body>
</html>
