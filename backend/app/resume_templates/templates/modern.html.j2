<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
@page { size: A4; margin: 1.4cm 1.6cm; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Helvetica Neue', Arial, Helvetica, sans-serif;
  font-size: 9.5pt;
  color: #2d2d2d;
  line-height: 1.4;
}
a { color: #2b6cb0; text-decoration: none; }

.header { margin-bottom: 10pt; }
.header h1 { font-size: 22pt; font-weight: 700; color: #2b6cb0; margin-bottom: 4pt; }
.contact { font-size: 8.5pt; color: #555; display: flex; flex-wrap: wrap; gap: 10pt; }
.contact-item::before { content: "● "; color: #2b6cb0; font-size: 7pt; }

section { margin-top: 10pt; }
.section-title {
  font-size: 9pt; font-weight: 700; color: #2b6cb0;
  text-transform: uppercase; letter-spacing: 0.6pt;
  border-bottom: 1.5px solid #2b6cb0; padding-bottom: 2pt; margin-bottom: 6pt;
}

.entry { margin-bottom: 7pt; }
.entry-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1pt; }
.entry-title { font-weight: 700; font-size: 9.5pt; color: #1a1a1a; }
.entry-company { color: #2b6cb0; font-size: 8.5pt; }
.entry-date { font-size: 8pt; color: #777; white-space: nowrap; }
.entry-location { font-size: 8pt; color: #888; margin-bottom: 2pt; }
.entry ul { padding-left: 0; list-style: none; }
.entry li { font-size: 9pt; padding-left: 1em; text-indent: -1em; margin-bottom: 1.5pt; color: #333; }
.entry li::before { content: "• "; color: #2b6cb0; }

.edu-entry { margin-bottom: 5pt; }
.edu-row { display: flex; justify-content: space-between; align-items: baseline; }
.edu-degree { font-weight: 700; }
.edu-inst { color: #2b6cb0; font-weight: 600; }
.edu-year { font-size: 8pt; color: #777; }
.edu-detail { font-size: 8.5pt; color: #666; }

.skill-row { font-size: 9pt; margin-bottom: 3pt; }
.skill-label { font-weight: 700; color: #2b6cb0; }
</style>
</head>
<body>

<div class="header">
  <h1>{{ data.name }}</h1>
  <div class="contact">
    {% if data.location %}<span class="contact-item">{{ data.location }}</span>{% endif %}
    {% if data.email %}<span class="contact-item">{{ data.email }}</span>{% endif %}
    {% if data.phone %}<span class="contact-item">{{ data.phone }}</span>{% endif %}
    {% if data.linkedin %}<span class="contact-item">{{ data.linkedin }}</span>{% endif %}
    {% if data.github %}<span class="contact-item">{{ data.github }}</span>{% endif %}
  </div>
</div>

{% if data.summary %}
<section>
  <div class="section-title">Professional Summary</div>
  <p style="font-size:9pt; color:#444; line-height:1.5;">{{ data.summary }}</p>
</section>
{% endif %}

{% if data.experience %}
<section>
  <div class="section-title">Professional Experience</div>
  {% for exp in data.experience %}
  <div class="entry">
    <div class="entry-header">
      <span class="entry-title">{{ exp.title }} | <span class="entry-company">{{ exp.company }}</span></span>
      <span class="entry-date">{{ exp.start_date }} — {{ exp.end_date }}{% if exp.location %}, {{ exp.location }}{% endif %}</span>
    </div>
    <ul>
      {% for bullet in exp.bullets %}
      <li>{{ bullet }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.projects %}
<section>
  <div class="section-title">Projects</div>
  {% for proj in data.projects %}
  <div class="entry">
    <div class="entry-header">
      <span class="entry-title">{{ proj.name }}</span>
      {% if proj.start_date %}<span class="entry-date">{{ proj.start_date }}{% if proj.end_date %} — {{ proj.end_date }}{% endif %}</span>{% endif %}
    </div>
    {% if proj.role %}<div class="entry-location">{{ proj.role }}{% if proj.organization %} · {{ proj.organization }}{% endif %}</div>{% endif %}
    <ul>{% for bullet in proj.bullets %}<li>{{ bullet }}</li>{% endfor %}</ul>
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.education %}
<section>
  <div class="section-title">Education</div>
  {% for edu in data.education %}
  <div class="edu-entry">
    <div class="edu-row">
      <span><span class="edu-degree">{{ edu.degree }}</span> | <span class="edu-inst">{{ edu.institution }}</span>{% if edu.location %} — {{ edu.location }}{% endif %}</span>
      <span class="edu-year">{{ edu.year }}</span>
    </div>
    {% if edu.honors %}<div class="edu-detail">{{ edu.honors }}</div>{% endif %}
    {% if edu.minor %}<div class="edu-detail">Minor in {{ edu.minor }}</div>{% endif %}
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.skills %}
<section>
  <div class="section-title">Expert-Level Skills</div>
  {% for cat in data.skills %}
  <div class="skill-row"><span class="skill-label">{{ cat.category }}:</span> {{ cat.skills | join(', ') }}</div>
  {% endfor %}
</section>
{% endif %}

</body>
</html>
