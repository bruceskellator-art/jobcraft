<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
@page { size: A4; margin: 0; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Helvetica Neue', Arial, Helvetica, sans-serif;
  font-size: 9.5pt;
  color: #222;
  line-height: 1.4;
}
a { color: inherit; text-decoration: none; }

.page { padding: 1.4cm 1.6cm; position: relative; overflow: hidden; }

/* Decorative arc top-right */
.page::before {
  content: "";
  position: absolute;
  top: -60px;
  right: -60px;
  width: 220px;
  height: 220px;
  background: #d6eaf8;
  border-radius: 50%;
  z-index: 0;
}

.header { position: relative; z-index: 1; margin-bottom: 10pt; }
.header h1 {
  font-size: 28pt; font-weight: 900; line-height: 1.05;
  color: #111; text-transform: none; margin-bottom: 5pt;
}
.contact { font-size: 8.5pt; color: #555; display: flex; flex-wrap: wrap; gap: 10pt; }
.contact span::before { content: "⊙ "; font-size: 8pt; color: #666; }

section { margin-top: 10pt; position: relative; z-index: 1; }
.section-title {
  font-size: 10pt; font-weight: 700; text-transform: none;
  margin-bottom: 5pt; color: #111;
  border-bottom: 2px solid #d6eaf8; padding-bottom: 2pt;
}

.entry { margin-bottom: 7pt; }
.entry-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1pt; }
.entry-title { font-weight: 700; font-size: 9.5pt; }
.entry-date { font-size: 8.5pt; color: #777; white-space: nowrap; }
.entry-sub { font-size: 8.5pt; color: #555; margin-bottom: 2pt; }
.entry ul { list-style: none; padding-left: 0; }
.entry li { font-size: 9pt; padding-left: 1em; text-indent: -1em; margin-bottom: 1.5pt; }
.entry li::before { content: "• "; color: #6ab0d4; }

.edu-entry { margin-bottom: 5pt; }
.edu-row { display: flex; justify-content: space-between; align-items: baseline; }
.edu-degree { font-weight: 700; }
.edu-detail { font-size: 8.5pt; color: #666; }

.skill-row { font-size: 9pt; margin-bottom: 2pt; }
.skill-label { font-weight: 700; }
</style>
</head>
<body>
<div class="page">

<div class="header">
  <h1>{{ data.name }}</h1>
  <div class="contact">
    {% if data.location %}<span>{{ data.location }}</span>{% endif %}
    {% if data.email %}<span>{{ data.email }}</span>{% endif %}
    {% if data.phone %}<span>{{ data.phone }}</span>{% endif %}
    {% if data.linkedin %}<span>{{ data.linkedin }}</span>{% endif %}
    {% if data.github %}<span>{{ data.github }}</span>{% endif %}
  </div>
</div>

{% if data.summary %}
<section>
  <div class="section-title">Professional Summary</div>
  <p style="font-size:9pt; color:#444; line-height:1.5;">{{ data.summary }}</p>
</section>
{% endif %}

{% if data.experience %}
<section>
  <div class="section-title">Professional Experience</div>
  {% for exp in data.experience %}
  <div class="entry">
    <div class="entry-header">
      <span class="entry-title">{{ exp.title }}</span>
      <span class="entry-date">{{ exp.start_date }} — {{ exp.end_date }}</span>
    </div>
    <div class="entry-sub">{{ exp.company }}{% if exp.location %} | {{ exp.location }}{% endif %}</div>
    <ul>
      {% for bullet in exp.bullets %}
      <li>{{ bullet }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.projects %}
<section>
  <div class="section-title">Projects</div>
  {% for proj in data.projects %}
  <div class="entry">
    <div class="entry-header">
      <span class="entry-title">{{ proj.role or proj.name }}</span>
      {% if proj.start_date %}<span class="entry-date">{{ proj.start_date }}{% if proj.end_date %} — {{ proj.end_date }}{% endif %}</span>{% endif %}
    </div>
    {% if proj.organization %}<div class="entry-sub">{{ proj.organization }}</div>{% endif %}
    <ul>{% for bullet in proj.bullets %}<li>{{ bullet }}</li>{% endfor %}</ul>
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.education %}
<section>
  <div class="section-title">Education</div>
  {% for edu in data.education %}
  <div class="edu-entry">
    <div class="edu-row">
      <span class="edu-degree">{{ edu.degree }}</span>
      <span style="font-size:8.5pt;color:#777;">{{ edu.year }}</span>
    </div>
    <div class="edu-detail">{{ edu.institution }}{% if edu.location %} — {{ edu.location }}{% endif %}{% if edu.minor %} · Minor in {{ edu.minor }}{% endif %}</div>
    {% if edu.honors %}<div class="edu-detail">{{ edu.honors }}</div>{% endif %}
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.skills %}
<section>
  <div class="section-title">Skills</div>
  {% for cat in data.skills %}
  <div class="skill-row"><span class="skill-label">{{ cat.category }}:</span> {{ cat.skills | join(', ') }}</div>
  {% endfor %}
</section>
{% endif %}

</div>
</body>
</html>
