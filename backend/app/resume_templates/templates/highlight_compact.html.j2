<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
@page { size: A4; margin: 0; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Helvetica Neue', Arial, Helvetica, sans-serif;
  font-size: 8.5pt;
  color: #222;
  line-height: 1.25;
}
a { color: inherit; text-decoration: none; }

.header { background: #1a2744; color: #fff; padding: 12pt 1.4cm 10pt; }
.header h1 { font-size: 18pt; font-weight: 700; color: #fff; margin-bottom: 3pt; }
.contact { font-size: 8pt; color: #b0bec5; display: flex; flex-wrap: wrap; gap: 10pt; }
.contact span::before { content: "● "; font-size: 6.5pt; color: #5c84b0; }

.body { padding: 8pt 1.4cm 1.2cm; }

section { margin-top: 6pt; }
.section-title {
  font-size: 8.5pt; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.5pt; color: #1a2744;
  border-bottom: 1.5px solid #1a2744; padding-bottom: 1pt; margin-bottom: 3pt;
}

.entry { margin-bottom: 5pt; }
.entry-header { display: flex; justify-content: space-between; align-items: baseline; }
.entry-title { font-weight: 700; font-size: 8.5pt; color: #1a2744; }
.entry-date { font-size: 7.5pt; color: #777; white-space: nowrap; }
.entry-company { font-size: 8pt; color: #555; margin-bottom: 1pt; }
.entry ul { list-style: none; padding-left: 0; }
.entry li { font-size: 8.5pt; padding-left: 0.9em; text-indent: -0.9em; margin-bottom: 0.5pt; }
.entry li::before { content: "• "; color: #1a2744; }

.edu-entry { margin-bottom: 4pt; }
.edu-row { display: flex; justify-content: space-between; }
.edu-degree { font-weight: 700; font-size: 8.5pt; }
.edu-detail { font-size: 8pt; color: #555; }

.skill-row { font-size: 8.5pt; margin-bottom: 1pt; }
.skill-label { font-weight: 700; color: #1a2744; }
</style>
</head>
<body>

<div class="header">
  <h1>{{ data.name }}</h1>
  <div class="contact">
    {% if data.location %}<span>{{ data.location }}</span>{% endif %}
    {% if data.email %}<span>{{ data.email }}</span>{% endif %}
    {% if data.phone %}<span>{{ data.phone }}</span>{% endif %}
    {% if data.linkedin %}<span>{{ data.linkedin }}</span>{% endif %}
    {% if data.github %}<span>{{ data.github }}</span>{% endif %}
  </div>
</div>

<div class="body">

{% if data.summary %}
<section>
  <div class="section-title">Summary</div>
  <p style="font-size:8.5pt; color:#444;">{{ data.summary }}</p>
</section>
{% endif %}

{% if data.experience %}
<section>
  <div class="section-title">Experience</div>
  {% for exp in data.experience %}
  <div class="entry">
    <div class="entry-header">
      <span class="entry-title">{{ exp.title }}</span>
      <span class="entry-date">{{ exp.start_date }} — {{ exp.end_date }}</span>
    </div>
    <div class="entry-company">{{ exp.company }}{% if exp.location %} · {{ exp.location }}{% endif %}</div>
    <ul>{% for bullet in exp.bullets %}<li>{{ bullet }}</li>{% endfor %}</ul>
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.projects %}
<section>
  <div class="section-title">Projects</div>
  {% for proj in data.projects %}
  <div class="entry">
    <div class="entry-header">
      <span class="entry-title">{{ proj.role or proj.name }}</span>
      {% if proj.start_date %}<span class="entry-date">{{ proj.start_date }}{% if proj.end_date %} — {{ proj.end_date }}{% endif %}</span>{% endif %}
    </div>
    {% if proj.organization %}<div class="entry-company">{{ proj.organization }}</div>{% endif %}
    <ul>{% for bullet in proj.bullets %}<li>{{ bullet }}</li>{% endfor %}</ul>
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.education %}
<section>
  <div class="section-title">Education</div>
  {% for edu in data.education %}
  <div class="edu-entry">
    <div class="edu-row">
      <span class="edu-degree">{{ edu.degree }}</span>
      <span style="font-size:7.5pt;color:#777;">{{ edu.year }}</span>
    </div>
    <div class="edu-detail">{{ edu.institution }}{% if edu.location %} · {{ edu.location }}{% endif %}{% if edu.minor %} · Minor in {{ edu.minor }}{% endif %}</div>
    {% if edu.honors %}<div class="edu-detail">{{ edu.honors }}</div>{% endif %}
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.skills %}
<section>
  <div class="section-title">Skills</div>
  {% for cat in data.skills %}
  <div class="skill-row"><span class="skill-label">{{ cat.category }}:</span> {{ cat.skills | join(', ') }}</div>
  {% endfor %}
</section>
{% endif %}

</div>
</body>
</html>
