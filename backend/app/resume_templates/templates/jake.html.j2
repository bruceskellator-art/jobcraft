<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
@page { size: A4; margin: 1.2cm 1.5cm; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Times New Roman', Times, Georgia, serif;
  font-size: 9.5pt;
  color: #000;
  line-height: 1.35;
}
a { color: inherit; text-decoration: none; }

.header { text-align: center; margin-bottom: 4pt; }
.header h1 { font-size: 18pt; font-weight: bold; margin-bottom: 3pt; }
.contact {
  font-size: 8.5pt;
  border-top: 1px solid #000;
  border-bottom: 1px solid #000;
  padding: 2pt 0;
  margin-top: 2pt;
}
.contact span + span::before { content: " | "; color: #555; }

section { margin-top: 6pt; }
.section-title {
  font-size: 9pt; font-weight: bold; text-transform: uppercase;
  letter-spacing: 0.5pt; border-bottom: 1.5px solid #000;
  padding-bottom: 1pt; margin-bottom: 4pt;
}

.entry { margin-bottom: 6pt; }
.entry-top { display: flex; justify-content: space-between; align-items: baseline; }
.entry-company { font-weight: bold; font-size: 9.5pt; }
.entry-location { font-size: 8.5pt; font-style: italic; }
.entry-mid { display: flex; justify-content: space-between; align-items: baseline; margin-top: 1pt; }
.entry-title { font-style: italic; font-size: 9pt; }
.entry-date { font-size: 8.5pt; font-style: italic; }
.entry ul { list-style: none; padding-left: 0; margin-top: 2pt; }
.entry li { font-size: 9pt; padding-left: 1em; text-indent: -1em; margin-bottom: 1pt; }
.entry li::before { content: "• "; }

.edu-entry { margin-bottom: 5pt; }
.edu-top { display: flex; justify-content: space-between; align-items: baseline; }
.edu-inst { font-weight: bold; }
.edu-loc { font-size: 8.5pt; font-style: italic; }
.edu-mid { display: flex; justify-content: space-between; align-items: baseline; }
.edu-degree { font-style: italic; font-size: 9pt; }
.edu-year { font-size: 8.5pt; font-style: italic; }
.edu-detail { font-size: 8.5pt; color: #333; }

.skill-row { font-size: 9pt; margin-bottom: 2pt; }
.skill-label { font-weight: bold; }
</style>
</head>
<body>

<div class="header">
  <h1>{{ data.name }}</h1>
  <div class="contact">
    {% if data.location %}<span>{{ data.location }}</span>{% endif %}
    {% if data.email %}<span>{{ data.email }}</span>{% endif %}
    {% if data.phone %}<span>{{ data.phone }}</span>{% endif %}
    {% if data.linkedin %}<span>{{ data.linkedin }}</span>{% endif %}
    {% if data.github %}<span>{{ data.github }}</span>{% endif %}
  </div>
</div>

{% if data.summary %}
<section>
  <div class="section-title">Summary</div>
  <p style="font-size:9pt; line-height:1.45;">{{ data.summary }}</p>
</section>
{% endif %}

{% if data.experience %}
<section>
  <div class="section-title">Experience</div>
  {% for exp in data.experience %}
  <div class="entry">
    <div class="entry-top">
      <span class="entry-company">{{ exp.company }}</span>
      <span class="entry-location">{% if exp.location %}{{ exp.location }}{% endif %}</span>
    </div>
    <div class="entry-mid">
      <span class="entry-title">{{ exp.title }}</span>
      <span class="entry-date">{{ exp.start_date }} — {{ exp.end_date }}</span>
    </div>
    <ul>
      {% for bullet in exp.bullets %}
      <li>{{ bullet }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.projects %}
<section>
  <div class="section-title">Projects</div>
  {% for proj in data.projects %}
  <div class="entry">
    <div class="entry-top">
      <span class="entry-company">{{ proj.name }}</span>
      {% if proj.start_date %}<span class="entry-date" style="font-style:italic;">{{ proj.start_date }}{% if proj.end_date %} — {{ proj.end_date }}{% endif %}</span>{% endif %}
    </div>
    {% if proj.role %}<div style="font-style:italic; font-size:9pt;">{{ proj.role }}{% if proj.organization %} | {{ proj.organization }}{% endif %}</div>{% endif %}
    <ul>{% for bullet in proj.bullets %}<li>{{ bullet }}</li>{% endfor %}</ul>
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.education %}
<section>
  <div class="section-title">Education</div>
  {% for edu in data.education %}
  <div class="edu-entry">
    <div class="edu-top">
      <span class="edu-inst">{{ edu.institution }}</span>
      <span class="edu-loc">{% if edu.location %}{{ edu.location }}{% endif %}</span>
    </div>
    <div class="edu-mid">
      <span class="edu-degree">{{ edu.degree }}{% if edu.minor %}, Minor in {{ edu.minor }}{% endif %}</span>
      <span class="edu-year">{{ edu.year }}</span>
    </div>
    {% if edu.honors %}<div class="edu-detail">{{ edu.honors }}</div>{% endif %}
  </div>
  {% endfor %}
</section>
{% endif %}

{% if data.skills %}
<section>
  <div class="section-title">Skills</div>
  {% for cat in data.skills %}
  <div class="skill-row"><span class="skill-label">{{ cat.category }}:</span> {{ cat.skills | join(', ') }}</div>
  {% endfor %}
</section>
{% endif %}

</body>
</html>
