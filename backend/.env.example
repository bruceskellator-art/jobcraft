# JobCraft backend environment variables
# Copy this file to .env and fill in your values.
# All variables use the JOBCRAFT_ prefix.

# Application
JOBCRAFT_APP_NAME=JobCraft
JOBCRAFT_ENVIRONMENT=development

# PostgreSQL (asyncpg driver)
JOBCRAFT_DATABASE_URL=postgresql+asyncpg://jobcraft:jobcraft@localhost:5432/jobcraft

# Qdrant vector store
JOBCRAFT_QDRANT_URL=http://localhost:6333

# Redis
JOBCRAFT_REDIS_URL=redis://localhost:6379/0

# Background scrape dispatch: "arq" (Redis/worker, scales across processes) or
# "inprocess" (run inside the API process, no Redis). Defaults to "arq" and
# falls back to in-process automatically if Redis is unreachable.
JOBCRAFT_SCRAPE_DISPATCH_MODE=arq

# CORS — comma-separated list of allowed origins (JSON array format)
JOBCRAFT_CORS_ORIGINS=["http://localhost:3000"]
