# JobCraft — environment variable reference
#
# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit secrets to version control.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with real values

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Matches the docker-compose.yml defaults for local dev.
JOBCRAFT_DATABASE_URL=postgresql+asyncpg://jobcraft:jobcraft@localhost:5432/jobcraft

# ── Vector Store ─────────────────────────────────────────────────────────────
# Qdrant REST endpoint.
# Matches the docker-compose.yml port mapping for local dev.
JOBCRAFT_QDRANT_URL=http://localhost:6333

# ── Job Queue (Phase 6+) ─────────────────────────────────────────────────────
# Redis connection string for arq workers.
# Uncomment the redis service in docker-compose.yml when enabling.
JOBCRAFT_REDIS_URL=redis://localhost:6379

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Which LLM backend to use. Options: anthropic (default), openai, deepseek.
# Set the matching API key below.
JOBCRAFT_LLM_PROVIDER=anthropic

# ── Embedding Provider ────────────────────────────────────────────────────────
# Options: openai (default, requires OPENAI_API_KEY), fake (no key needed).
# Use fake for local dev/demos when you don't have an OpenAI key.
JOBCRAFT_EMBEDDING_PROVIDER=openai

# ── Vector Store ──────────────────────────────────────────────────────────────
# Options: qdrant (default, requires Qdrant running), memory (in-process, no infra).
# Use memory for local dev/demos without Docker.
JOBCRAFT_VECTOR_STORE=qdrant

# ── LLM API Keys ─────────────────────────────────────────────────────────────
# Fill in the key for the provider you selected above. Others can be left blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
JINA_API_KEY=
